{
  "version": "2.1.0",
  "$schema": "https://raw.githubusercontent.com/oasis-tcs/sarif-spec/master/Schemata/sarif-schema-2.1.0.json",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "GoldenScan",
          "version": "1.0.0",
          "rules": [
            {"id": "CWE-78", "name": "CommandInjection"},
            {"id": "CWE-502", "name": "InsecureDeserialization"}
          ]
        }
      },
      "results": [
        {
          "ruleId": "CWE-78",
          "level": "error",
          "message": {"text": "Shell command built from unsanitized input"},
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {"uri": "src/one.py"},
                "region": {"startLine": 3}
              }
            }
          ]
        },
        {
          "ruleId": "CWE-502",
          "level": "warning",
          "message": {"text": "Untrusted data passed to pickle.loads"},
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {"uri": "src/three.py"},
                "region": {"startLine": 5}
              }
            }
          ]
        }
      ]
    }
  ]
}
