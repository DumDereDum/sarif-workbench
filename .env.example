# ── Логирование ───────────────────────────────────────────────────────────────
# INFO  — только ключевые события (старт анализа, вердикты, итог)
# DEBUG — полные тексты запросов/ответов к LLM
LOG_LEVEL=INFO
# Путь к файлу логов (пусто = только stdout)
# В Docker пробрасывается как ./logs/server.log на хосте
LOG_FILE=/logs/server.log

# ── Хранилище данных ──────────────────────────────────────────────────────────
DATA_DIR=/data

# ── База данных ───────────────────────────────────────────────────────────────
# SQLite (по умолчанию):
DATABASE_URL=sqlite:////data/swb.db

# Postgres (раскомментировать для перехода):
# DATABASE_URL=postgresql://swb:swb@postgres:5432/swb

# ── Лимиты входных данных ─────────────────────────────────────────────────────
# Сервер: максимальный размер каждого файла загрузки (SARIF и swbmeta), в МБ.
# Файл крупнее отклоняется с HTTP 413 (payload_too_large) до чтения в память целиком.
SWB_MAX_UPLOAD_MB=50

# CLI (swb-cli enrich): максимальный размер исходника для извлечения сниппета, в МБ.
# Файл крупнее пропускается (code=null + warning в stderr), не читается целиком.
# Переменная берётся из окружения процесса swb-cli, не из этого файла.
SWB_MAX_SOURCE_MB=10

# ── AI-триаж (POST /runs/{id}/analyze) ────────────────────────────────────────
# Circuit breaker (T-37): после стольких подряд идущих ошибок провайдера
# (битый ключ, провайдер лежит и т.п.) цикл анализа останавливается сам,
# не перебирая остальные находки с таймаутами. 0 или отрицательное — выключен.
SWB_ANALYZE_MAX_CONSECUTIVE_ERRORS=5

# Реестр AI-провайдеров (T-41/T-42). Пусто = единственный встроенный дефолт —
# локальный Ollama-совместимый провайдер (http://localhost:11434/v1), ни один
# анализ не уходит за пределы localhost. JSON-массив записей
# {"name", "base_url", "local", "default_model", "api_key_env"}; SWB_AI_PROVIDERS_FILE
# (путь к файлу с тем же форматом) приоритетнее SWB_AI_PROVIDERS, если заданы оба.
# SWB_AI_PROVIDERS=[{"name":"vllm-local","base_url":"http://localhost:8000/v1","local":true}]
# SWB_AI_PROVIDERS_FILE=/etc/swb/providers.json

# "api_key_env" (T-44) — имя ENV-переменной сервера, где лежит настоящий ключ
# провайдера; сам ключ никогда не кладётся в SWB_AI_PROVIDERS/SWB_AI_PROVIDERS_FILE
# как есть (эти файлы/переменные — конфиг, который может попасть в git/логи/дамп).
# Клиент (web UI) ключ не хранит и не передаёт вообще — GET /api/v1/providers
# отдаёт только name/local/default_model. Для локальных провайдеров ("local": true)
# api_key_env не нужен — большинство локальных инференс-серверов Authorization не проверяют.
# SWB_AI_PROVIDERS=[{"name":"deepseek","base_url":"https://api.deepseek.com","local":false,"default_model":"deepseek-chat","api_key_env":"SWB_DEEPSEEK_API_KEY"}]
# SWB_DEEPSEEK_API_KEY=sk-...

# Провайдеры с "local": false (облачные, например DeepSeek) зарегистрированы,
# но не вызываемы, пока явно не разрешено ОБА условия — просто флага мало,
# т.к. base_url конфигурируем (SSRF-защита, inspection/03-security.md §2, §5):
SWB_ALLOW_REMOTE_PROVIDERS=false
# Хосты, куда разрешено обращаться remote-провайдерам (через запятую).
# Пусто = ни один remote-провайдер не доступен, даже если флаг выше = true.
SWB_REMOTE_PROVIDER_ALLOWLIST=

# ── Хранилище BLOB-файлов ─────────────────────────────────────────────────────
STORAGE_BACKEND=local

# S3 / MinIO (раскомментировать для перехода):
# STORAGE_BACKEND=s3
# S3_ENDPOINT=http://minio:9000
# S3_BUCKET=swb
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_REGION=us-east-1

# ── docker-compose.prod.yml: креды опциональных сервисов ─────────────────────
# Нужны ТОЛЬКО для сервисов postgres/minio (профили --profile postgres / --profile s3,
# make prod-full), но docker compose подставляет переменные для всех сервисов файла
# при разборе, поэтому без них падает даже обычный `make prod` (server+web).
# Замени плейсхолдеры на свои значения перед запуском.

# Учётка Postgres (сервис postgres в docker-compose.prod.yml, profile: postgres).
POSTGRES_USER=changeme-postgres-user
# Пароль Postgres — не используй значение по умолчанию из образа.
POSTGRES_PASSWORD=changeme-postgres-password

# Root-учётка MinIO (сервис minio в docker-compose.prod.yml, profile: s3).
MINIO_ROOT_USER=changeme-minio-user
# Пароль MinIO — минимум 8 символов (требование самого MinIO).
MINIO_ROOT_PASSWORD=changeme-minio-password
